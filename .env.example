# ── Proxy authentication ──────────────────────────────────────────────────────
# Client API key (set this to any strong secret you choose)
API_KEY=sk-your-proxy-key
REQUIRE_AUTH=true

# ── DeepSeek official API ─────────────────────────────────────────────────────
ENABLE_DEEPSEEK=true
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic   # default
# DEEPSEEK_MODELS_URL=https://api.deepseek.com/models    # default

# ── Aliyun DashScope ──────────────────────────────────────────────────────────
ENABLE_DASHSCOPE=true
DASHSCOPE_API_KEY=sk-your-dashscope-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic              # default
# DASHSCOPE_MODELS_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/models # default

# ── Model allowlist (optional) ────────────────────────────────────────────────
# Comma-separated. Leave empty to expose all models from enabled providers.
# ALLOWED_MODELS=deepseek-v4-pro,glm-5,kimi-k2.5

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=INFO
TIMEOUT=300
